# =============================================================================
# KnonixAI — customer install configuration
# =============================================================================
# Copy once, then either:
#   A) Run ./install.sh  (recommended — interactive wizard fills required fields)
#   B) Edit this file, then: ./install.sh
#
# REQUIRED before production use:
#   1. POSTGRES_PASSWORD          — strong unique password (not "change-me…")
#   2. KNONIX_LICENSE_SERVICE_TOKEN — fleet enrollment token from Knonix
#      (sales@knonix.com or your license email). Enables seat tracking.
# OPTIONAL but common:
#   3. KNONIX_DOMAIN + KNONIX_ACME_EMAIL — HTTPS on your domain
#   4. Microsoft / Google OAuth — enterprise SSO
# =============================================================================

# --- Image -------------------------------------------------------------------
KNONIX_IMAGE_TAG=latest

# --- Public domain + HTTPS (optional) ----------------------------------------
# Leave blank → http://localhost:3000
# Set domain  → https://<domain> with automatic Let's Encrypt via Caddy
KNONIX_DOMAIN=
KNONIX_ACME_EMAIL=
# Auto-filled by install.sh when domain is set:
# KNONIX_PUBLIC_URL=https://your.domain
# NEXT_PUBLIC_BASE_URL=https://your.domain

# --- Database (REQUIRED) -----------------------------------------------------
POSTGRES_USER=knonixai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=knonixai

# --- Sovereign local inference -----------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# Defaults tuned for 8–16 GB CPU hosts (raise on GPU / large RAM)
OLLAMA_NUM_CTX=3072
OLLAMA_NUM_PREDICT=768
OLLAMA_KEEP_ALIVE=-1
# Chat + coding models (install.sh pulls these)
KNONIX_MODEL=qwen3:8b
KNONIX_CODING_MODEL=qwen2.5-coder:7b

# --- Multi-user accounts (ON by default) -------------------------------------
# install.sh auto-generates JWT secrets + GoTrue keys. First user who signs up
# becomes the organization owner and can open /admin.
ENABLE_AUTH=true
KNONIX_AUTH_MAILER_AUTOCONFIRM=true
# Set true after SMTP is configured to require email confirmation:
# KNONIX_AUTH_MAILER_AUTOCONFIRM=false

# Auto-generated by install.sh (leave blank):
# KNONIX_AUTH_JWT_SECRET=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# KNONIX_AUTH_API_EXTERNAL_URL=
# KNONIX_AUTH_SITE_URL=
# KNONIX_AUTH_ADDITIONAL_REDIRECT_URLS=

# --- Optional enterprise SSO -------------------------------------------------
# Redirect URI for both providers:
#   <NEXT_PUBLIC_SUPABASE_URL>/auth/v1/callback
# KNONIX_AUTH_GOOGLE_ENABLED=true
# KNONIX_AUTH_GOOGLE_CLIENT_ID=
# KNONIX_AUTH_GOOGLE_SECRET=
# KNONIX_AUTH_AZURE_ENABLED=true
# KNONIX_AUTH_AZURE_CLIENT_ID=
# KNONIX_AUTH_AZURE_SECRET=
# Authority base ONLY (no /v2.0 suffix — GoTrue appends /oauth2/v2.0/ itself).
# Commercial multi-tenant:
# KNONIX_AUTH_AZURE_URL=https://login.microsoftonline.com/common
# Commercial single tenant:
# KNONIX_AUTH_AZURE_URL=https://login.microsoftonline.com/YOUR-TENANT-ID
# GCC High / Azure Government (portal.azure.us app registration):
# KNONIX_AUTH_AZURE_URL=https://login.microsoftonline.us/YOUR-TENANT-ID

# --- Optional SMTP (password reset + feedback mail) --------------------------
# KNONIX_AUTH_SMTP_HOST=
# KNONIX_AUTH_SMTP_PORT=587
# KNONIX_AUTH_SMTP_USER=
# KNONIX_AUTH_SMTP_PASS=
# KNONIX_AUTH_SMTP_ADMIN_EMAIL=noreply@your.domain
# KNONIX_AUTH_SMTP_SENDER_NAME=KnonixAI

# --- Fleet licensing & seat reporting (CONNECTED by default) -----------------
# PRODUCT RULE: every customer install gets 1 free user (KNONIX_FREE_SEATS=1).
# Additional users are paid (per-seat billing via fleet upgrade / Stripe).
# Heartbeats contain NO PII — only opaque install hash, license key, seat count,
# and version. See Admin → License after first sign-up.
#
# Modes: free | connected | offline
KNONIX_LICENSE_MODE=connected
KNONIX_FREE_SEATS=1
# Leave false for all customer installs. Only the Knonix platform host may set true.
KNONIX_PLATFORM_OWNER=false
# Central License Service (Knonix-operated fleet board)
KNONIX_LICENSE_SERVICE_URL=https://ai.knonix.com
# REQUIRED for fleet reporting — paste the enrollment token Knonix gave you:
KNONIX_LICENSE_SERVICE_TOKEN=
# Auto-assigned on first admin sign-up (or paste a pre-provisioned key):
# KNONIX_LICENSE_KEY=
# Auto-generated by install.sh — enables daily seat heartbeats:
# KNONIX_HEARTBEAT_SECRET=

# Offline / air-gapped (no network to Knonix) — token from sales@knonix.com:
# KNONIX_LICENSE_MODE=offline
# KNONIX_LICENSE_TOKEN=
# KNONIX_LICENSE_PUBLIC_KEY=

# --- Connectors (Microsoft 365 / Google) — optional --------------------------
# Auto-generated by install.sh (encrypts OAuth tokens at rest):
# KNONIX_CONNECTOR_ENCRYPTION_KEY=
# KNONIX_MS_OAUTH_CLIENT_ID=
# KNONIX_MS_OAUTH_CLIENT_SECRET=
# KNONIX_MS_CLOUD_ENVIRONMENT=commercial
# KNONIX_MS_TENANT_ID=

# --- Knowledge / RAG (ON — stays in-boundary) --------------------------------
KNONIX_RAG_ENABLED=true
# KNONIX_RAG_EMBED_MODEL=nomic-embed-text

# --- Frontier APIs (OFF — sends data outside your boundary) ------------------
KNONIX_ALLOW_FRONTIER=false
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROK_API_KEY=

# --- Platform mode (customers leave as sovereign) ----------------------------
# KNONIX_PLATFORM_MODE=sovereign
# KNONIX_STUDIO_ENABLED=true

# --- Code workspace (GitHub / GitLab / local) --------------------------------
# Optional install-wide PATs for private repo clones (users can also paste per project).
# KNONIX_GITHUB_TOKEN=
# KNONIX_GITLAB_TOKEN=
# Host folder bind-mounted into the app as /host (local projects):
# KNONIX_HOST_MOUNT=/home/knonix
