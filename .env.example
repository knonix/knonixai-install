# KnonixAI customer install — copy to .env and run ./install.sh
# Never commit real secrets. install.sh mints JWT/Redis secrets automatically.

# --- Image pin (P2-2) --------------------------------------------------------
# Prefer a release tag once published, e.g. v1.6.1. Use never for air-gap after docker load.
KNONIX_IMAGE_TAG=latest
KNONIX_IMAGE_PULL_POLICY=missing
# OLLAMA_IMAGE_TAG=latest
# SEARXNG_IMAGE_TAG=latest

# --- Database ----------------------------------------------------------------
POSTGRES_USER=knonixai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=knonixai
# Optional in-cluster TLS: ./scripts/enable-db-tls.sh
# POSTGRES_SSL=true
# DATABASE_SSL_DISABLED=false
# DATABASE_SSL_QUERY=?sslmode=require

# --- Redis (requirepass; install.sh generates REDIS_PASSWORD) ----------------
# REDIS_PASSWORD=
# LOCAL_REDIS_URL=redis://:PASSWORD@redis:6379

# --- Domain / HTTPS ----------------------------------------------------------
# KNONIX_DOMAIN=
# KNONIX_ACME_EMAIL=
# KNONIX_PUBLIC_URL=
# NEXT_PUBLIC_BASE_URL=

# --- GPU (install.sh sets true when nvidia-smi + toolkit work) ---------------
# KNONIX_GPU=false

# --- Ollama / models (P0-4, P1-1, P1-3) --------------------------------------
# Instruct defaults (NOT qwen3:8b thinking). CPU/low: 3b; GPU/high: 7b.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1
OLLAMA_TEMPERATURE=0.6
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.1
INFERENCE_MAX_OUTPUT_TOKENS=4096
# Default assumes capable host; install.sh hardware-profile may lower to 3b on CPU/Mac.
KNONIX_MODEL=qwen2.5:7b
KNONIX_CODING_MODEL=qwen2.5-coder:7b
# Optional deep reasoning (not default): KNONIX_MODEL=qwen3:8b

# --- Auth (invite-only by default) -------------------------------------------
ENABLE_AUTH=true
KNONIX_AUTH_DISABLE_SIGNUP=true
KNONIX_AUTH_MAILER_AUTOCONFIRM=false
# First owner (interactive install prompts; cleared after success):
# KNONIX_BOOTSTRAP_ADMIN_EMAIL=
# KNONIX_BOOTSTRAP_ADMIN_PASSWORD=
# KNONIX_AUTH_JWT_TTL_DAYS=365
# KNONIX_AUTH_JWT_SECRET=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=

# --- Licensing (default offline — no seat egress) ----------------------------
# offline | free | connected  (connected enables heartbeat-cron profile)
KNONIX_LICENSE_MODE=offline
KNONIX_FREE_SEATS=1
KNONIX_PLATFORM_OWNER=false
# Only for connected mode (opt-in):
# KNONIX_LICENSE_SERVICE_URL=https://ai.knonix.com
# KNONIX_LICENSE_SERVICE_TOKEN=
# KNONIX_HEARTBEAT_SECRET=

# --- Frontier APIs (OFF = sovereign) -----------------------------------------
KNONIX_ALLOW_FRONTIER=false
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- RAG / search ------------------------------------------------------------
KNONIX_RAG_ENABLED=true
KNONIX_RAG_EMBED_MODEL=nomic-embed-text
KNONIX_RAG_EMBED_DIM=768
SEARCH_API=searxng
SEARXNG_API_URL=http://searxng:8080
# SEARXNG_SECRET=   # install.sh generates

# --- Air-gap helper ----------------------------------------------------------
# ./scripts/airgap-mode.sh
