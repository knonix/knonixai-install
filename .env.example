# KnonixAI install configuration.
# Copy to .env and edit before running: cp .env.example .env
#
# This install pulls the prebuilt KnonixAI image from GHCR. You do NOT need
# source access — only permission to pull the image (see README.md).

# --- Image version -----------------------------------------------------------
# Pin to a specific release (e.g. v1.2.0) for reproducible deploys. Defaults to
# "latest" if unset.
KNONIX_IMAGE_TAG=latest

# --- Public domain + HTTPS (optional) ----------------------------------------
# Leave BOTH blank to serve the app on http://localhost:3000 (no proxy).
#
# Set KNONIX_DOMAIN to serve over HTTPS on your own domain with automatic
# Let's Encrypt certificates via a bundled Caddy reverse proxy. install.sh
# detects this and enables the proxy automatically, so the app is reachable at
# https://<KNONIX_DOMAIN>/ and https://<KNONIX_DOMAIN>/admin (no port numbers).
#
# Requirements for public HTTPS:
#   - A DNS A/AAAA record for KNONIX_DOMAIN pointing at this host's public IP
#   - Ports 80 and 443 open to the internet (Let's Encrypt challenges)
# Tip: set KNONIX_DOMAIN=localhost to test HTTPS locally with a self-signed CA.
#
# Example: KNONIX_DOMAIN=sub.domain.com
KNONIX_DOMAIN=
KNONIX_ACME_EMAIL=

# --- Local stack credentials (bundled Postgres/Redis) ------------------------
POSTGRES_USER=knonixai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=knonixai

# --- Sovereign local inference -----------------------------------------------
# The bundled Ollama service runs models inside your boundary. No data leaves.
OLLAMA_BASE_URL=http://ollama:11434

# --- Licensing & seats -------------------------------------------------------
# Free tier = KNONIX_FREE_SEATS active seats (default 2). Beyond that a license
# is required (per-seat billing). A seat = a user active in the last 30 days.
#
# Modes:
#   free      - up to KNONIX_FREE_SEATS seats, no license needed (default)
#   connected - periodic privacy-preserving heartbeat to the Knonix License
#               Service so seats are metered/billed. Set the values below.
#   offline   - air-gapped; validate a signed license token (no connectivity).
#               For 3+ seats offline, contact sales@knonix.com.
KNONIX_LICENSE_MODE=free
KNONIX_FREE_SEATS=2

# Connected mode (fill these in when you have a license):
# KNONIX_LICENSE_KEY=KNX-XXXX-XXXX-XXXX-XXXX
# KNONIX_LICENSE_SERVICE_URL=https://ai.knonix.com
# KNONIX_LICENSE_SERVICE_TOKEN=   # provided by Knonix; pairs with the service
# KNONIX_INSTANCE_ID=             # optional stable id; auto-derived if unset

# Offline mode (air-gapped) — token + public key provided by Knonix:
# KNONIX_LICENSE_TOKEN=
# KNONIX_LICENSE_PUBLIC_KEY=

# --- Frontier APIs (OFF by default — NON-SOVEREIGN) --------------------------
# Enabling these sends prompts/data to third-party clouds and breaks data
# sovereignty. Only enable where your compliance boundary allows it.
KNONIX_ALLOW_FRONTIER=false
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROK_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
