# KnonixAI install configuration.
# Copy to .env and edit before running: cp .env.example .env
#
# This install pulls the prebuilt KnonixAI image from GHCR. You do NOT need
# source access — only permission to pull the image (see README.md).

# --- Image version -----------------------------------------------------------
# Pin to a specific release (e.g. v1.2.0) for reproducible deploys. Defaults to
# "latest" if unset.
KNONIX_IMAGE_TAG=latest

# --- Public domain + HTTPS (optional) ----------------------------------------
# Leave BOTH blank to serve the app on http://localhost:3000 (no proxy).
#
# Set KNONIX_DOMAIN to serve over HTTPS on your own domain with automatic
# Let's Encrypt certificates via a bundled Caddy reverse proxy. install.sh
# detects this and enables the proxy automatically, so the app is reachable at
# https://<KNONIX_DOMAIN>/ and https://<KNONIX_DOMAIN>/admin (no port numbers).
#
# Requirements for public HTTPS:
#   - A DNS A/AAAA record for KNONIX_DOMAIN pointing at this host's public IP
#   - Ports 80 and 443 open to the internet (Let's Encrypt challenges)
# Tip: set KNONIX_DOMAIN=localhost to test HTTPS locally with a self-signed CA.
#
# Example: KNONIX_DOMAIN=sub.domain.com
KNONIX_DOMAIN=
KNONIX_ACME_EMAIL=

# --- Local stack credentials (bundled Postgres/Redis) ------------------------
POSTGRES_USER=knonixai
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=knonixai

# --- Sovereign local inference -----------------------------------------------
# The bundled Ollama service runs models inside your boundary. No data leaves.
OLLAMA_BASE_URL=http://ollama:11434

# --- Multi-user accounts (self-hosted, in-boundary) --------------------------
# ON by default. The install runs its own GoTrue + Kong auth services next to
# the app (see docker-compose.yml), so users can create real accounts — local
# email/password plus Google and Microsoft (Entra) sign-in — with NO cloud
# Supabase. Everything stays inside your sovereign / GCC boundary.
#
# install.sh handles ALL of the plumbing for you on first run:
#   - generates KNONIX_AUTH_JWT_SECRET and the anon/service_role API keys
#   - fills in NEXT_PUBLIC_SUPABASE_URL + the auth callback/site URLs
#   - creates the `auth` schema in Postgres
# You do not need to touch anything below unless you want to opt out or add SSO.
#
# To run single-user / anonymous instead (no login screen), set:
#   ENABLE_AUTH=false
ENABLE_AUTH=true

# Signups auto-confirm so accounts work without an email server. Set to false
# only after configuring an in-boundary SMTP server (KNONIX_AUTH_SMTP_*).
KNONIX_AUTH_MAILER_AUTOCONFIRM=true
# KNONIX_AUTH_DISABLE_SIGNUP=false   # set true to make the instance invite-only

# The following are AUTO-GENERATED by install.sh on first run and written back
# to this file. Leave them blank to let the installer manage them; set them
# yourself only if you are supplying your own keys or pointing at an external
# GoTrue. (NEXT_PUBLIC_SUPABASE_URL defaults to your KNONIX_DOMAIN, or
# http://localhost:8000 in local mode.)
# KNONIX_AUTH_JWT_SECRET=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# KNONIX_AUTH_API_EXTERNAL_URL=
# KNONIX_AUTH_SITE_URL=
# KNONIX_AUTH_ADDITIONAL_REDIRECT_URLS=

# --- Optional: Google + Microsoft (Entra) sign-in ----------------------------
# Register a web OAuth app with each provider and set its redirect URL to:
#   <NEXT_PUBLIC_SUPABASE_URL>/auth/v1/callback
# then uncomment + fill in the matching pair below and re-run install.sh.
# KNONIX_AUTH_GOOGLE_ENABLED=true
# KNONIX_AUTH_GOOGLE_CLIENT_ID=
# KNONIX_AUTH_GOOGLE_SECRET=
# KNONIX_AUTH_AZURE_ENABLED=true
# KNONIX_AUTH_AZURE_CLIENT_ID=
# KNONIX_AUTH_AZURE_SECRET=
# Pin a single tenant (GCC High authority shown):
# KNONIX_AUTH_AZURE_URL=https://login.microsoftonline.us/YOUR-TENANT-ID/v2.0

# --- Optional: in-boundary SMTP (only if AUTOCONFIRM=false) ------------------
# KNONIX_AUTH_SMTP_HOST=
# KNONIX_AUTH_SMTP_PORT=587
# KNONIX_AUTH_SMTP_USER=
# KNONIX_AUTH_SMTP_PASS=
# [email protected]
# KNONIX_AUTH_SMTP_SENDER_NAME=KnonixAI

# --- Licensing & seats -------------------------------------------------------
# Free tier = KNONIX_FREE_SEATS active seats (default 2). Beyond that a license
# is required (per-seat billing). A seat = a user active in the last 30 days.
#
# Modes:
#   free      - up to KNONIX_FREE_SEATS seats, no license needed (default)
#   connected - periodic privacy-preserving heartbeat to the Knonix License
#               Service so seats are metered/billed. Set the values below.
#   offline   - air-gapped; validate a signed license token (no connectivity).
#               For 3+ seats offline, contact sales@knonix.com.
KNONIX_LICENSE_MODE=free
KNONIX_FREE_SEATS=2

# Connected mode (fill these in when you have a license):
# KNONIX_LICENSE_KEY=KNX-XXXX-XXXX-XXXX-XXXX
# KNONIX_LICENSE_SERVICE_URL=https://ai.knonix.com
# KNONIX_LICENSE_SERVICE_TOKEN=   # provided by Knonix; pairs with the service
# KNONIX_INSTANCE_ID=             # optional stable id; auto-derived if unset

# Offline mode (air-gapped) — token + public key provided by Knonix:
# KNONIX_LICENSE_TOKEN=
# KNONIX_LICENSE_PUBLIC_KEY=

# --- RAG / knowledge base (ON by default — sovereign, in-boundary) -----------
KNONIX_RAG_ENABLED=true
# KNONIX_RAG_EMBED_MODEL=nomic-embed-text
# KNONIX_RAG_EMBED_DIM=768

# --- Frontier APIs (OFF by default — NON-SOVEREIGN) --------------------------
# Enabling these sends prompts/data to third-party clouds and breaks data
# sovereignty. Only enable where your compliance boundary allows it.
KNONIX_ALLOW_FRONTIER=false
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROK_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
