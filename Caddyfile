# KnonixAI reverse proxy (Caddy) — CUSTOMER installs
#
# Automatic HTTPS via Let's Encrypt. Caddy provisions and renews certificates
# for {$KNONIX_DOMAIN} automatically on first request. No port numbers, no
# manual certs.
#
# Requirements for public HTTPS:
#   - A DNS A/AAAA record for KNONIX_DOMAIN pointing at this host's public IP
#   - Ports 80 and 443 reachable from the internet (Let's Encrypt HTTP/TLS
#     challenges)
#   - KNONIX_ACME_EMAIL set (used for expiry/renewal notices)
#
# For local testing without a real domain, set KNONIX_DOMAIN=localhost — Caddy
# then serves HTTPS with a locally-trusted internal CA (no Let's Encrypt).
#
# Platform fleet host (ai.knonix.com only): use Caddyfile.platform via
# docker-compose.platform.yml — not this file.

{
	email {$KNONIX_ACME_EMAIL}
	# For staging/testing against Let's Encrypt without hitting rate limits,
	# uncomment the next line:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$KNONIX_DOMAIN} {
	# NEVER gzip/zstd SSE/chat streams — compression buffers until the model
	# finishes, so the UI looks like chat "never answers" on CPU hosts.
	@compressible {
		not path /api/chat* /api/coding* /api/knonix/models/pull*
		not header Content-Type *text/event-stream*
	}
	encode @compressible zstd gzip

	# Self-hosted auth gateway (GoTrue via Kong). Requests to
	# https://{$KNONIX_DOMAIN}/supabase/* are forwarded to Kong with the
	# /supabase prefix stripped, so the app's NEXT_PUBLIC_SUPABASE_URL can be
	# https://{$KNONIX_DOMAIN}/supabase. Active only when auth is enabled; the
	# route is harmless if the Kong service isn't running.
	handle_path /supabase/* {
		reverse_proxy supabase-kong:8000
	}

	# Model pulls stream for a long time — disable proxy buffering/timeouts.
	handle /api/knonix/models/pull* {
		reverse_proxy knonixai:3000 {
			flush_interval -1
			transport http {
				read_timeout 2h
				write_timeout 2h
			}
		}
	}

	# Chat / coding SSE streams — flush immediately so clients see tokens/tools
	# and do not surface a generic "network error" while the local model works.
	handle /api/chat* {
		reverse_proxy knonixai:3000 {
			flush_interval -1
			transport http {
				read_timeout 15m
				write_timeout 15m
				response_header_timeout 15m
			}
		}
	}
	handle /api/coding* {
		reverse_proxy knonixai:3000 {
			flush_interval -1
			transport http {
				read_timeout 15m
				write_timeout 15m
				response_header_timeout 15m
			}
		}
	}

	# App (Next.js) — everything else routes here by default.
	reverse_proxy knonixai:3000 {
		flush_interval -1
		transport http {
			read_timeout 10m
			write_timeout 10m
		}
	}

	# The admin dashboard is served by the app at /admin, so it is reachable
	# at https://{$KNONIX_DOMAIN}/admin with no port number.

	# Optional: expose self-hosted search under a path instead of a port.
	# Uncomment to serve SearXNG at https://{$KNONIX_DOMAIN}/search-engine/
	# handle_path /search-engine/* {
	# 	reverse_proxy searxng:8080
	# }

	header {
		# Basic hardening
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
